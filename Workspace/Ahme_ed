) {
    IconButton(
        onClick = onClick,
        modifier = Modifier
            .size(AppTopBarDefaults.navigationButtonSize)
            .semantics {
                this.contentDescription = contentDescription
            }
    ) {
        Icon(
            imageVector = Icons.Filled.ArrowBack,
            contentDescription = null,
            tint = MaterialTheme.colorScheme.onSurface
        )
    }
}
